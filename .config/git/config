[core]
    editor = nvim

[alias]
  nuke = "!f() { \
    git fetch origin && \
    read -p 'Are you sure you want to NUKE all of your local changes? [y/N] ' yn; \
    case $yn in \
      [Yy]*) \
        git reset --hard origin/$(git branch --show-current) && \
        git clean -df \
        ;; \
      esac \
    }; f"
